# Environment Variables Configuration
# Copy this file to .env and customize as needed

# Database Configuration
DATABASE_URL=sqlite:///pds_platform.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/pds_db
# For MySQL: DATABASE_URL=mysql+pymysql://user:password@localhost:3306/pds_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRATION_HOURS=24

# ML Model Configuration
ML_MODEL_PATH=backend/ml/models/fraud_detection_model.pkl
ML_CONTAMINATION_RATE=0.1
ML_ANOMALY_THRESHOLD=0.5

# Fraud Detection Thresholds
FRAUD_RISK_THRESHOLD=0.5
HIGH_QUANTITY_THRESHOLD=50.0
MAX_TRANSACTIONS_PER_DAY=2
DUPLICATE_TIME_WINDOW_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FILE=pds_platform.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
CORS_ENABLED=True

# Email Notifications (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=admin@pdsteam.com

# Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_TIMEOUT_MINUTES=60

# Database Pool Configuration
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
